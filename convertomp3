#!/usr/bin/env bash
set -euo pipefail

[[ -z "${1-}" ]] && {
	echo "Usage: $0 /path/to/folder"
	exit 1
}

folder="$1"
mkdir -p "$folder/converted_audio" "$folder/converted_video"

declare -A ext_map=(
	[mp3]=audio [wav]=audio [flac]=audio [aac]=audio
	[m4a]=audio [wma]=audio [ogg]=audio
	[mp4]=video [mkv]=video [mov]=video [wmv]=video
	[flv]=video [webm]=video
)

for f in "$folder"/*; do
	[[ -f "$f" ]] || continue
	ext="${f##*.}"
	ext="${ext,,}"
	name="$(basename "${f%.*}")"

	case "${ext_map[$ext]-}" in
	audio)
		echo "Converting audio: $(basename "$f") → ${name}.mp3"
		ffmpeg -i "$f" -codec:a libmp3lame -b:a 192k "$folder/converted_audio/${name}.mp3" -y
		;;
	video)
		echo "Converting video: $(basename "$f") → ${name}.avi"
		ffmpeg -i "$f" -c:v mpeg4 -vtag xvid -qscale:v 5 -c:a mp3 -b:a 192k "$folder/converted_video/${name}.avi" -y
		;;
	*)
		echo "Skipping unsupported file: $(basename "$f")"
		;;
	esac
done

echo "Conversion complete."
